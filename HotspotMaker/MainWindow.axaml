<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hm="using:HotspotMaker"
        xmlns:hotspot="using:HotspotMaker.Hotspot"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="HotspotMaker.MainWindow"
        x:DataType="hm:MainWindowVM"
        Title="{Binding WindowTitle}">
    <!-- NOTE: HotKeys in menu items don't work until a menu has been opened at least once, for some reason, hence these key bindings: -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenWadFile}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCurrentProject}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCurrentProject}" />
        <KeyBinding Gesture="Alt+F4" Command="{Binding ExitProgram}" />
        <KeyBinding Gesture="Ctrl+X" Command="{Binding CutSelection}" />
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelection}" />
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteSelection}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoLastAction}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoLastAction}" />
    </Window.KeyBindings>
    <Grid RowDefinitions="Auto,*,Auto">
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open wad file" InputGesture="Ctrl+O" Command="{Binding OpenWadFile}" />
                <!-- TODO: Show recent files! -->
                <Separator />
                <MenuItem Header="_Save" InputGesture="Ctrl+S" Command="{Binding SaveCurrentProject}" IsEnabled="{Binding HasOpenProject}" />
                <Separator />
                <MenuItem Header="_Close" InputGesture="Ctrl+W" Command="{Binding CloseCurrentProject}" IsEnabled="{Binding HasOpenProject}" />
                <Separator />
                <MenuItem Header="E_xit" InputGesture="Alt+F4" Command="{Binding ExitProgram}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Cu_t" InputGesture="Ctrl+X" Command="{Binding CutSelection}" IsEnabled="{Binding IsCutAvailable}" />
                <MenuItem Header="_Copy" InputGesture="Ctrl+C" Command="{Binding CopySelection}" IsEnabled="{Binding IsCopyAvailable}" />
                <MenuItem Header="_Paste" InputGesture="Ctrl+V" Command="{Binding PasteSelection}" IsEnabled="{Binding IsPasteAvailable}" />
                <Separator />
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z" Command="{Binding UndoLastAction}" IsEnabled="{Binding IsUndoAvailable}" />
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y" Command="{Binding RedoLastAction}" IsEnabled="{Binding IsRedoAvailable}" />
            </MenuItem>
            <!--<MenuItem Header="Help">
                <MenuItem Header="About" />
            </MenuItem>-->
        </Menu>

        <Grid Grid.Row="1">
            <hotspot:HotspotProjectView x:Name="ProjectView" Grid.Row="1" DataContext="{Binding HotspotProject}" IsVisible="{Binding $parent[Window].DataContext.HasOpenProject}" />
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" HorizontalAlignment="Left" Margin="5" />
    </Grid>
</Window>
